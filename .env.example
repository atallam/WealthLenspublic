# ============================================================
# WealthLens OSS — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
# PostgreSQL (production):
DATABASE_URL=postgresql://wealthlens:changeme@localhost:5432/wealthlens
# SQLite (development):
# DATABASE_URL=sqlite:///./wealthlens.db

# --- Security ---
SECRET_KEY=CHANGE-ME-to-a-64-char-random-string
ENCRYPTION_MASTER_SALT=CHANGE-ME-another-random-string-for-key-derivation

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- AI Advisor (optional) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Market Data: Twelve Data (optional, free: 800 calls/day) ---
# Get from: https://twelvedata.com/account → API Keys
TWELVE_DATA_API_KEY=your-twelve-data-api-key

# --- Google OAuth (optional — enables "Sign in with Google") ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Redis (optional — market data cache, recommended for production) ---
REDIS_URL=redis://localhost:6379/0

# --- Database Pool (PostgreSQL only) ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Google OAuth (optional — enables "Sign in with Google") ---
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Server ---
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
